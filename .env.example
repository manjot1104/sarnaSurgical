# ============ LOCAL DEVELOPMENT ============
# Copy to .env and fill in values

# MongoDB (when integrated)
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster.mongodb.net/sarnaSurgical

# Security
ADMIN_PASSWORD=your-strong-admin-password

# ============ RENDER (Backend) ============
NODE_ENV=production
FRONTEND_URL=https://sarna-surgical.vercel.app
ADMIN_PASSWORD=your-strong-admin-password
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster.mongodb.net/sarnaSurgical

# ============ VERCEL (Frontend) ============
# Add in Vercel Dashboard → Settings → Environment Variables
# Then REDEPLOY (required for Vite env vars to take effect)
VITE_API_URL=https://your-app-name.onrender.com
