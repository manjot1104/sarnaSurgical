# ============ LOCAL DEVELOPMENT ============
# Copy to .env and fill in values

# MongoDB (recommended for production — persists orders & products across deploys)
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster.mongodb.net/sarnaSurgical

# Security
ADMIN_PASSWORD=your-strong-admin-password

# Frontend URL (for CORS + email links)
FRONTEND_URL=https://sarna-surgical.vercel.app

# Email — Gmail SMTP (use App Password, not regular password)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your-gmail-app-password
EMAIL_FROM=your@gmail.com
EMAIL_FROM_NAME=Sarna Surgical
ADMIN_EMAIL=your@gmail.com

# ============ RENDER (Backend) ============
# Add all of the above in Render → Environment Variables

# ============ VERCEL (Frontend) ============
VITE_API_URL=https://your-app-name.onrender.com
